{
  "name": "jupysql-labextension",
  "version": "0.11.2",
  "description": "JupySQL JupyterLab Extension - Database Browser",
  "keywords": [
    "jupyter",
    "jupyterlab",
    "jupyterlab-extension",
    "sql",
    "database"
  ],
  "homepage": "https://github.com/ploomber/jupysql",
  "bugs": {
    "url": "https://github.com/ploomber/jupysql/issues"
  },
  "license": "Apache-2.0",
  "author": {
    "name": "Ploomber",
    "email": "contact@ploomber.io"
  },
  "files": [
    "src/**/*.{ts,tsx}",
    "style/**/*.{css,js}",
    "lib/**/*.{js,ts,map}"
  ],
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "style": "style/index.css",
  "styleModule": "style/index.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/ploomber/jupysql.git"
  },
  "scripts": {
    "build": "npm run build:lib && npm run build:labextension:dev",
    "build:prod": "npm run build:lib:prod && npm run build:labextension",
    "build:labextension": "jupyter labextension build .",
    "build:labextension:dev": "jupyter labextension build .",
    "build:lib": "tsc --sourceMap",
    "build:lib:prod": "tsc",
    "clean": "npm run clean:lib && npm run clean:labextension",
    "clean:lib": "rimraf lib tsconfig.tsbuildinfo",
    "clean:all": "npm run clean:lib && npm run clean:labextension",
    "clean:labextension": "rimraf ../jupysql/labextension",
    "watch": "npm-run-all -p watch:src watch:labextension",
    "watch:src": "tsc -w --sourceMap",
    "watch:labextension": "jupyter labextension watch ."
  },
  "dependencies": {
    "@jupyterlab/application": "^4.0.0",
    "@jupyterlab/apputils": "^4.0.0",
    "@jupyterlab/coreutils": "^6.0.0",
    "@jupyterlab/services": "^7.0.0",
    "@jupyterlab/ui-components": "^4.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@jupyterlab/builder": "^4.0.0",
    "npm-run-all": "^4.1.5",
    "rimraf": "^5.0.1",
    "typescript": "~5.6.2"
  },
  "sideEffects": [
    "style/*.css",
    "style/index.js"
  ],
  "publishConfig": {
    "access": "public"
  },
  "jupyterlab": {
    "extension": true,
    "outputDir": "../jupysql/labextension"
  }
}
